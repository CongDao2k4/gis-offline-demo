{
  "version": 8,
  "name": "VietNam Style",
  "center": [
    105.85,
    21.03
  ],
  "zoom": 12,
  "glyphs": "{fontstack}/{range}.pbf",
  "sources": {
    "vietnam": {
      "type": "vector",
      "url": "mbtiles://{vietnam}",
      "minzoom": 4,
      "maxzoom": 16
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f3f3f3"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "vietnam",
      "source-layer": "water",
      "minzoom": 4,
      "paint": {
        "fill-color": "#9fd3ff",
        "fill-opacity": 0.85
      }
    },
    {
      "id": "water-lines",
      "type": "line",
      "source": "vietnam",
      "source-layer": "water_lines",
      "minzoom": 4,
      "paint": {
        "line-color": "#5dade2",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          4,
          0.3,
          10,
          1.2,
          14,
          3,
          16,
          5
        ]
      }
    },
    {
      "id": "water-labels",
      "type": "symbol",
      "source": "vietnam",
      "source-layer": "water_lines",
      "minzoom": 4,
      "layout": {
        "symbol-placement": "line",
        "text-field": [
          "get",
          "name"
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          4,
          8,
          14,
          11,
          16,
          13
        ]
      },
      "paint": {
        "text-color": "#2e86c1",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },
    {
      "id": "poi-labels",
      "type": "symbol",
      "source": "vietnam",
      "source-layer": "poi",
      "minzoom": 4,
      "layout": {
        "text-field": [
          "get",
          "name"
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          4,
          7,
          14,
          10,
          16,
          12
        ]
      },
      "paint": {
        "text-color": "#444444",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "vietnam",
      "source-layer": "landuse",
      "paint": {
        "fill-color": "#d8f0d2",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "vietnam",
      "source-layer": "buildings",
      "minzoom": 4,
      "paint": {
        "fill-color": "#d9d0c9",
        "fill-outline-color": "#b8aea6",
        "fill-opacity": 0.8
      }
    },
    {
      "id": "planned-roads",
      "type": "line",
      "source": "vietnam",
      "source-layer": "planned_roads",
      "minzoom": 4,
      "paint": {
        "line-color": "#777777",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          4,
          0.3,
          10,
          0.7,
          14,
          3,
          16,
          5
        ],
        "line-dasharray": [
          2,
          2
        ],
        "line-opacity": 0.55
      }
    },
    {
      "id": "roads-minor",
      "type": "line",
      "source": "vietnam",
      "source-layer": "roads",
      "minzoom": 4,
      "filter": [
        "in",
        [
          "get",
          "class"
        ],
        [
          "literal",
          [
            "residential",
            "living_street",
            "service",
            "unclassified",
            "track",
            "path",
            "footway",
            "pedestrian",
            "cycleway"
          ]
        ]
      ],
      "paint": {
        "line-color": "#9a9a9a",
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          4,
          0.15,
          10,
          0.5,
          14,
          2,
          16,
          4
        ],
        "line-opacity": 0.75
      }
    },
    {
      "id": "roads-major",
      "type": "line",
      "source": "vietnam",
      "source-layer": "roads",
      "minzoom": 4,
      "filter": [
        "in",
        [
          "get",
          "class"
        ],
        [
          "literal",
          [
            "motorway",
            "trunk",
            "primary",
            "secondary",
            "tertiary"
          ]
        ]
      ],
      "paint": {
        "line-color": [
          "match",
          [
            "get",
            "class"
          ],
          "motorway",
          "#e63946",
          "trunk",
          "#f77f00",
          "primary",
          "#fcbf49",
          "secondary",
          "#ffd166",
          "tertiary",
          "#ffe599",
          "#555555"
        ],
        "line-width": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          4,
          0.3,
          10,
          1.2,
          14,
          4,
          16,
          6
        ]
      }
    },
    {
      "id": "road-labels",
      "type": "symbol",
      "source": "vietnam",
      "source-layer": "roads",
      "minzoom": 4,
      "layout": {
        "symbol-placement": "line",
        "text-field": [
          "get",
          "name"
        ],
        "text-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          4,
          7,
          14,
          11,
          16,
          13
        ],
        "text-font": [
          "Noto Sans Regular"
        ]
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    }
  ]
}
